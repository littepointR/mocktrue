<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="portweave"
        Arguments=""
        InstallLocation="C:\Program Files\PortWeave\PortWeave">
    </Installer>
    <PackageInformation
        PackageName="PortWeave"
        PackageDisplayName="PortWeave"
        PublisherName="CN=PortWeave"
        PublisherDisplayName="PortWeave"
        Version="0.1.0.0"
        PackageDescription="Cross-platform embedded debugging toolkit">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.portweave.app"
                Description="Cross-platform embedded debugging toolkit"
                DisplayName="PortWeave"
                ExecutableName="portweave"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>PortWeave</DisplayName>
            <PublisherDisplayName>PortWeave</PublisherDisplayName>
            <Description>Cross-platform embedded debugging toolkit</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="portweave.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
