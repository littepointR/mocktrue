{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "vue-tsc && vite build --minify false --mode development",
    "build": "vue-tsc && vite build --mode production",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:mock": "playwright test",
    "e2e:wails": "MOCKTRUE_E2E_MODE=wails playwright test"
  },
  "dependencies": {
    "@tanstack/vue-virtual": "^3.13.29",
    "@wailsio/runtime": "latest",
    "monaco-editor": "^0.55.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "splitpanes": "^4.1.2",
    "vue": "^3.2.45",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^4.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^1.0.11"
  }
}
